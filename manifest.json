{
  "manifest_version": 3,
  "name": "MarmoUI",
  "version": "2.1.0",
  "description": "A modern skin for UW's Marmoset submission server: themes, live deadline countdowns, inline scores and tokens, easy submissions.",
  "homepage_url": "https://github.com/Rishi-Ahuja/MarmoUI",
  "minimum_chrome_version": "111",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://marmoset.student.cs.uwaterloo.ca/*"
      ],
      "css": [
        "styles.css"
      ],
      "js": [
        "src/early-theme.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://marmoset.student.cs.uwaterloo.ca/*"
      ],
      "js": [
        "src/constants.js",
        "src/utils.js",
        "src/mode.js",
        "src/dates.js",
        "src/theme.js",
        "src/tables.js",
        "src/palette.js",
        "src/submit.js",
        "src/loaders.js",
        "src/problems.js",
        "src/pages.js",
        "legacy/legacy-css.js",
        "legacy/legacy.js",
        "src/main.js"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "fonts/*.woff2"
      ],
      "matches": [
        "https://marmoset.student.cs.uwaterloo.ca/*"
      ]
    }
  ]
}
